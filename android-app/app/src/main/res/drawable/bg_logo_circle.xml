<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow ring -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#FF3B5C18"/>
            <stroke android:width="1dp" android:color="#FF3B5C33"/>
        </shape>
    </item>
    <!-- Inner solid -->
    <item android:top="12dp" android:bottom="12dp" android:left="12dp" android:right="12dp">
        <shape android:shape="oval">
            <solid android:color="#1A0A10"/>
            <stroke android:width="1.5dp" android:color="#FF3B5C66"/>
        </shape>
    </item>
</layer-list>
