<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0D1829"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>
    <!-- Subtle gradient overlay -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#FFFFFF0A"
                android:endColor="#00000000"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>
    <!-- Top highlight line -->
    <item android:bottom="0dp" android:left="0dp" android:right="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#FF3B5C00"
                android:centerColor="#FF3B5C44"
                android:endColor="#FF3B5C00"/>
            <size android:height="1dp"/>
            <corners android:topLeftRadius="24dp" android:topRightRadius="24dp"/>
        </shape>
    </item>
    <!-- Border -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#FF3B5C22"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>
</layer-list>
